@page "{id:guid}"
@model PilotsRUs.Admin.App.Pages.Manufacturers.DeleteModel
@{
    ViewData["Title"] = "Delete manufacturer";
}

<div class="card">
    <div class="card-body">
        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        @if (Model.TargetManufacturer is not null)
        {
            <p>Delete <strong>@Model.TargetManufacturer.Name</strong>? This cannot be undone.</p>

            <form method="post">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-page="/Manufacturers/Index" class="btn btn-secondary">Cancel</a>
            </form>
        }
    </div>
</div>
