@page
@model PilotsRUs.Admin.App.Pages.Schedules.IndexModel
@{
    ViewData["Title"] = "Schedules";
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Flight #</th>
                    <th>Departure</th>
                    <th>Arrival</th>
                    <th>Aircraft</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var schedule in Model.Schedules)
                {
                    <tr>
                        <td>@schedule.FlightDate</td>
                        <td>@schedule.FlightNumber</td>
                        <td>@schedule.DepartureAirportIcaoCode - @schedule.DepartureAirportName</td>
                        <td>@schedule.ArrivalAirportIcaoCode - @schedule.ArrivalAirportName</td>
                        <td>@schedule.AircraftRegistrationNumber</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
