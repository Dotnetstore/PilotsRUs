@page "{id:guid}"
@model PilotsRUs.Admin.App.Pages.ScheduleTemplates.DeleteModel
@{
    ViewData["Title"] = "Delete schedule template";
}

<div class="card">
    <div class="card-body">
        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        @if (Model.TargetScheduleTemplate is not null)
        {
            <p>Delete <strong>@Model.TargetScheduleTemplate.FlightNumber</strong> (@Model.TargetScheduleTemplate.DepartureAirportIcaoCode &rarr; @Model.TargetScheduleTemplate.ArrivalAirportIcaoCode)? This cannot be undone.</p>

            <form method="post">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-page="/ScheduleTemplates/Index" class="btn btn-secondary">Cancel</a>
            </form>
        }
    </div>
</div>
