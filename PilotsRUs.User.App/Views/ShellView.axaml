<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PilotsRUs.User.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
             x:Class="PilotsRUs.User.App.Views.ShellView"
             x:DataType="vm:ShellViewModel">

    <StackPanel Spacing="12" Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="{Binding DisplayName, StringFormat='Welcome, {0}!'}" FontSize="20" FontWeight="Bold" />
        <Button Content="Log out" Command="{Binding LogoutCommand}" IsEnabled="{Binding !IsBusy}" HorizontalAlignment="Center" />
    </StackPanel>
</UserControl>
